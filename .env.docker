# PostgreSQL settings
POSTGRES_USER=salesflow
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=salesflow

# App port (host port mapped to container 3000)
APP_PORT=3000

# NextAuth — MUST change NEXTAUTH_SECRET in production
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=change_me_in_production_use_openssl_rand_hex_32
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI (MiniMax / Anthropic-compatible)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
